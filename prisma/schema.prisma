generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  ACTIVE
  ARCHIVED
}

enum RoleName {
  TEACHER
  ACADEMIC_COORDINATOR
  REVIEWER
  SCHOOL_ADMIN
}

enum QuestionType {
  MULTIPLE_CHOICE
  SHORT_ANSWER
  LONG_ANSWER
  TRUE_FALSE
  FILL_IN_THE_BLANK
  MATCHING
}

enum QuestionStatus {
  DRAFT
  READY
  NEEDS_REVIEW
  ARCHIVED
}

enum SourceType {
  TEACHER_CREATED
  SCHOOL_OWNED
  LICENSED
  OPEN
  PUBLIC_DOMAIN
  VERIFIED_PARTNER
}

enum RightsStatus {
  VERIFIED
  NEEDS_REVIEW
  RESTRICTED
}

enum UploadStatus {
  PENDING
  STORED
  PROCESSING
  FAILED
}

enum PaperStatus {
  DRAFT
  VALIDATING
  READY_FOR_REVIEW
  ARCHIVED
}

enum TemplateStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum TemplateType {
  EXAM
  ASSIGNMENT
  WORKSHEET
  ANSWER_KEY
  RUBRIC
}

enum ValidationSeverity {
  INFO
  WARNING
  ERROR
}

enum ValidationTargetType {
  QUESTION
  PAPER
  TEMPLATE
  UPLOAD
  EXPORT
}

enum ApprovalStatus {
  REQUESTED
  APPROVED
  CHANGES_REQUESTED
  CANCELLED
}

model School {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  campuses          Campus[]
  workspaces        Workspace[]
  roles             Role[]
  subjects          Subject[]
  grades            Grade[]
  uploads           Upload[]
  mediaAssets       MediaAsset[]
  questionSources   QuestionSource[]
  questions         Question[]
  papers            Paper[]
  templates         Template[]
  rubrics           Rubric[]
  validationResults ValidationResult[]
  approvalRequests  ApprovalRequest[]
  comments          Comment[]
  auditLogs         AuditLog[]
}

model Campus {
  id        String       @id @default(cuid())
  schoolId  String
  name      String
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  school     School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspaces Workspace[]

  @@index([schoolId])
}

model Workspace {
  id            String       @id @default(cuid())
  schoolId      String
  campusId      String?
  name          String
  defaultLocale String       @default("en")
  status        RecordStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  campus            Campus?            @relation(fields: [campusId], references: [id], onDelete: SetNull)
  roles             Role[]
  subjects          Subject[]
  grades            Grade[]
  chapters          Chapter[]
  subtopics         Subtopic[]
  uploads           Upload[]
  mediaAssets       MediaAsset[]
  questionSources   QuestionSource[]
  questions         Question[]
  papers            Paper[]
  templates         Template[]
  rubrics           Rubric[]
  validationResults ValidationResult[]
  approvalRequests  ApprovalRequest[]
  comments          Comment[]
  auditLogs         AuditLog[]

  @@index([schoolId])
  @@index([campusId])
}

model User {
  id        String       @id @default(cuid())
  name      String
  email     String       @unique
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  roles             Role[]
  uploads           Upload[]
  questionSources   QuestionSource[]
  questions         Question[]
  questionVersions  QuestionVersion[]
  papers            Paper[]
  templates         Template[]
  comments          Comment[]
  auditLogs         AuditLog[]
  approvalRequests  ApprovalRequest[] @relation("ApprovalRequester")
  approvalDecisions ApprovalRequest[] @relation("ApprovalDecider")
}

model Role {
  id          String       @id @default(cuid())
  schoolId    String
  workspaceId String?
  userId      String
  name        RoleName
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, workspaceId, userId, name])
  @@index([userId])
}

model Subject {
  id          String       @id @default(cuid())
  schoolId    String
  workspaceId String
  name        String
  code        String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chapters  Chapter[]
  questions Question[]
  papers    Paper[]

  @@unique([workspaceId, name])
  @@index([schoolId, workspaceId])
}

model Grade {
  id          String       @id @default(cuid())
  schoolId    String
  workspaceId String
  name        String
  order       Int
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  questions Question[]
  papers    Paper[]

  @@unique([workspaceId, name])
  @@index([schoolId, workspaceId])
}

model Chapter {
  id          String       @id @default(cuid())
  schoolId    String
  workspaceId String
  subjectId   String
  name        String
  order       Int
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subtopics Subtopic[]
  questions Question[]

  @@unique([subjectId, name])
  @@index([schoolId, workspaceId])
}

model Subtopic {
  id          String       @id @default(cuid())
  schoolId    String
  workspaceId String
  chapterId   String
  name        String
  order       Int
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chapter   Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  questions Question[]

  @@unique([chapterId, name])
  @@index([schoolId, workspaceId])
}

model QuestionSource {
  id              String       @id @default(cuid())
  schoolId        String
  workspaceId     String
  uploadId        String?
  createdById     String
  sourceType      SourceType
  title           String
  author          String?
  owner           String?
  license         String?
  rightsStatus    RightsStatus @default(NEEDS_REVIEW)
  usageRights     String
  attributionText String?
  originalUrl     String?
  verifiedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  upload    Upload?    @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  createdBy User       @relation(fields: [createdById], references: [id], onDelete: Restrict)
  questions Question[]

  @@index([schoolId, workspaceId])
  @@index([uploadId])
}

model Question {
  id          String         @id @default(cuid())
  schoolId    String
  workspaceId String
  sourceId    String
  subjectId   String
  gradeId     String
  chapterId   String?
  subtopicId  String?
  createdById String
  type        QuestionType
  prompt      String
  marks       Int
  difficulty  String?
  status      QuestionStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  school         School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  source         QuestionSource    @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  subject        Subject           @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  grade          Grade             @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  chapter        Chapter?          @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  subtopic       Subtopic?         @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  createdBy      User              @relation(fields: [createdById], references: [id], onDelete: Restrict)
  versions       QuestionVersion[]
  paperQuestions PaperQuestion[]
  answerKeys     AnswerKey[]

  @@index([schoolId, workspaceId])
  @@index([subjectId, gradeId])
}

model QuestionVersion {
  id               String   @id @default(cuid())
  questionId       String
  editedById       String
  versionNumber    Int
  promptSnapshot   String
  metadataSnapshot Json
  changeReason     String?
  createdAt        DateTime @default(now())

  question       Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  editedBy       User            @relation(fields: [editedById], references: [id], onDelete: Restrict)
  answerKey      AnswerKey?
  paperQuestions PaperQuestion[]

  @@unique([questionId, versionNumber])
}

model Upload {
  id               String       @id @default(cuid())
  schoolId         String
  workspaceId      String
  uploadedById     String
  filename         String
  contentType      String
  byteSize         Int
  storageKey       String
  sourceType       SourceType
  rightsStatus     RightsStatus @default(NEEDS_REVIEW)
  usageRights      String
  processingStatus UploadStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedBy      User             @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  questionSources QuestionSource[]
  mediaAssets     MediaAsset[]

  @@index([schoolId, workspaceId])
}

model MediaAsset {
  id           String        @id @default(cuid())
  schoolId     String
  workspaceId  String
  uploadId     String?
  filename     String
  contentType  String
  byteSize     Int
  storageKey   String
  sourceType   SourceType?
  rightsStatus RightsStatus?
  usageRights  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  upload    Upload?   @relation(fields: [uploadId], references: [id], onDelete: SetNull)

  @@index([schoolId, workspaceId])
}

model Paper {
  id                String      @id @default(cuid())
  schoolId          String
  workspaceId       String
  subjectId         String
  gradeId           String
  templateVersionId String?
  createdById       String
  title             String
  status            PaperStatus @default(DRAFT)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subject         Subject          @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  grade           Grade            @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  templateVersion TemplateVersion? @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  createdBy       User             @relation(fields: [createdById], references: [id], onDelete: Restrict)
  sections        PaperSection[]
  answerKey       AnswerKey?
  rubrics         Rubric[]

  @@index([schoolId, workspaceId])
}

model PaperSection {
  id           String   @id @default(cuid())
  paperId      String
  title        String
  instructions String?
  order        Int
  marks        Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  paper     Paper           @relation(fields: [paperId], references: [id], onDelete: Cascade)
  questions PaperQuestion[]

  @@unique([paperId, order])
}

model PaperQuestion {
  id                String   @id @default(cuid())
  paperSectionId    String
  questionId        String
  questionVersionId String?
  order             Int
  marksOverride     Int?
  displaySettings   Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  section         PaperSection     @relation(fields: [paperSectionId], references: [id], onDelete: Cascade)
  question        Question         @relation(fields: [questionId], references: [id], onDelete: Restrict)
  questionVersion QuestionVersion? @relation(fields: [questionVersionId], references: [id], onDelete: SetNull)

  @@unique([paperSectionId, order])
  @@index([questionId])
}

model Template {
  id          String         @id @default(cuid())
  schoolId    String
  workspaceId String?
  createdById String
  name        String
  type        TemplateType
  status      TemplateStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  school    School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User              @relation(fields: [createdById], references: [id], onDelete: Restrict)
  versions  TemplateVersion[]

  @@index([schoolId, workspaceId])
}

model TemplateVersion {
  id            String   @id @default(cuid())
  templateId    String
  versionNumber Int
  structure     Json
  changeReason  String?
  createdAt     DateTime @default(now())

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  papers   Paper[]

  @@unique([templateId, versionNumber])
}

model Rubric {
  id          String   @id @default(cuid())
  schoolId    String
  workspaceId String
  paperId     String?
  title       String
  criteria    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  paper     Paper?    @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@index([schoolId, workspaceId])
}

model AnswerKey {
  id                String   @id @default(cuid())
  questionId        String?
  questionVersionId String?  @unique
  paperId           String?  @unique
  content           Json
  isComplete        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  question        Question?        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionVersion QuestionVersion? @relation(fields: [questionVersionId], references: [id], onDelete: SetNull)
  paper           Paper?           @relation(fields: [paperId], references: [id], onDelete: Cascade)
}

model ValidationResult {
  id           String               @id @default(cuid())
  schoolId     String
  workspaceId  String
  targetType   ValidationTargetType
  targetId     String
  severity     ValidationSeverity
  code         String
  message      String
  field        String?
  suggestedFix String?
  createdAt    DateTime             @default(now())

  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([schoolId, workspaceId])
  @@index([targetType, targetId])
}

model ApprovalRequest {
  id            String               @id @default(cuid())
  schoolId      String
  workspaceId   String
  requestedById String
  decidedById   String?
  targetType    ValidationTargetType
  targetId      String
  status        ApprovalStatus       @default(REQUESTED)
  requestedAt   DateTime             @default(now())
  decidedAt     DateTime?

  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestedBy User      @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  decidedBy   User?     @relation("ApprovalDecider", fields: [decidedById], references: [id], onDelete: Restrict)
  comments    Comment[]

  @@index([schoolId, workspaceId])
  @@index([targetType, targetId])
}

model Comment {
  id                String               @id @default(cuid())
  schoolId          String
  workspaceId       String
  authorId          String
  approvalRequestId String?
  targetType        ValidationTargetType
  targetId          String
  body              String
  resolvedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author          User             @relation(fields: [authorId], references: [id], onDelete: Restrict)
  approvalRequest ApprovalRequest? @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)

  @@index([schoolId, workspaceId])
  @@index([targetType, targetId])
}

model AuditLog {
  id          String   @id @default(cuid())
  schoolId    String
  workspaceId String?
  actorId     String?
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  school    School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  actor     User?      @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([schoolId, workspaceId])
  @@index([targetType, targetId])
}
